# ============================================================
#  Lumi — Variables de entorno
#  Renombrar este archivo a .env y completar los valores
# ============================================================

# ── WhatsApp Business API (Meta) ────────────────────────────
WA_TOKEN=EAAB...          # Token de acceso permanente de Meta
WA_PHONE_ID=1234567890    # Phone Number ID (en Meta for Developers)
VERIFY_TOKEN=lumi_klinge  # Token que tú defines al registrar el webhook en Meta

# ── Anthropic (Claude AI) ───────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# ── Lioren API ──────────────────────────────────────────────
LIOREN_TOKEN=...          # Desde Lioren: APIs → Administrar APIs → Token de acceso

# ── Servidor ────────────────────────────────────────────────
PORT=3000
PUBLIC_URL=https://tu-dominio.cl   # URL pública para servir los PDFs generados
PDF_OUTPUT_DIR=/tmp/cotizaciones   # Directorio local para PDFs temporales
